VM1_USER=root
VM1_PASS=change-me
VM2_USER=root
VM2_PASS=change-me

# Postgres connection string (local DB or Supabase pooled Postgres URL)
# Example:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/osyrus
# Supabase usually requires SSL:
# DATABASE_SSL=require
DATABASE_URL=
DATABASE_SSL=

# Optional runtime controls
# PORTAL_DB_REQUIRED=true
# PORTAL_DB_AUTO_IMPORT=true

# Patch workflow / RBAC tokens
# Set a global token or role-specific tokens:
# OSYRUS_PATCH_TOKEN=change-me
# OSYRUS_PATCH_REQUEST_TOKEN=change-me
# OSYRUS_PATCH_APPROVE_TOKEN=change-me
# OSYRUS_PATCH_EXECUTE_TOKEN=change-me
OSYRUS_PATCH_TOKEN=
OSYRUS_PATCH_REQUEST_TOKEN=
OSYRUS_PATCH_APPROVE_TOKEN=
OSYRUS_PATCH_EXECUTE_TOKEN=

# Patch execution mode and Ansible settings
# Use dry-run first, then switch to live after validation
OSYRUS_PATCH_EXECUTION_MODE=dry-run
OSYRUS_PATCH_PLAYBOOK=ansible/playbooks/osyrus_patch_workflow.yml
OSYRUS_PATCH_INVENTORY=ansible/inventory/hosts.ini
