VM1_USER=root
VM1_PASS=change-me
VM2_USER=root
VM2_PASS=change-me

# Postgres connection string (local DB or Supabase pooled Postgres URL)
# Example:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/osyrus
# Supabase usually requires SSL:
# DATABASE_SSL=require
DATABASE_URL=
DATABASE_SSL=

# Optional runtime controls
# PORTAL_DB_REQUIRED=true
# PORTAL_DB_AUTO_IMPORT=true
